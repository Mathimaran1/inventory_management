# ============================================================
# Inventory and Purchase System - Environment Variables Example
# ============================================================
# Copy this file as .env and fill in your actual values.

# ---- Application Settings ----
APP_NAME=Inventory and Purchase System
APP_VERSION=1.0.0
DEBUG=True

# ---- MongoDB Settings ----
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=inventory_db

# ---- JWT Settings ----
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
